<Window x:Class="DB.Workbench.QueryWorkbench"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DB Workbench Client" Height="720" Width="1060" MinHeight="610" MinWidth="850"
        Background="#171827" WindowStartupLocation="CenterScreen">
    <DockPanel Margin="14">
        <Border DockPanel.Dock="Top" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="6" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="76"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Host" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="HostBox" Grid.Column="1" Text="localhost"/>
                <TextBlock Grid.Column="2" Text="Port" VerticalAlignment="Center" Margin="16,0,8,0"/>
                <TextBox x:Name="PortBox" Grid.Column="3" Text="5432"/>
                <Button Grid.Column="4" Content="Connect" Click="Connect_Click"/>
                <Button Grid.Column="5" Content="Disconnect" Click="Disconnect_Click"/>
                <Button Grid.Column="6" Content="Connection test" Click="ConnectionTest_Click"/>
                <TextBlock x:Name="ConnectionStateText" Grid.Column="8" Text="Disconnected" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <StatusBar DockPanel.Dock="Bottom" Background="{StaticResource PanelBrush}" Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready. Start server: ./build/customdb_server --host 0.0.0.0 --port 5432" Foreground="{StaticResource MutedTextBrush}"/>
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="0,4,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="230"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="150"/>
            </Grid.RowDefinitions>

            <GroupBox Header="SQL Request">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock DockPanel.Dock="Left" Text="Examples" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="ExampleBox" SelectionChanged="ExampleBox_SelectionChanged">
                            <ComboBoxItem Content="Employees demo"/>
                            <ComboBoxItem Content="Products with TEXT[]"/>
                            <ComboBoxItem Content="Show catalog"/>
                            <ComboBoxItem Content="Clean demo database"/>
                        </ComboBox>
                    </DockPanel>
                    <TextBox x:Name="SqlBox" Grid.Row="1" FontFamily="Consolas" FontSize="14" AcceptsReturn="True" AcceptsTab="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Content="Execute  Ctrl+Enter / F5" Click="Execute_Click" Background="#006bbd"/>
                        <Button Content="Clear" Click="Clear_Click"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Row="1" Header="Result Table">
                <DataGrid x:Name="ResultGrid"/>
            </GroupBox>

            <GroupBox Grid.Row="2" Header="Response Inspector">
                <TextBox x:Name="ResponseBox" FontFamily="Consolas" FontSize="12" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>
